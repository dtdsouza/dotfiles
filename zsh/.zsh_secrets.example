# ~/.zsh_secrets  (machine-local, NEVER committed)
#
# Copy this file to ~/.zsh_secrets and fill in real values.
# It is sourced at the end of ~/.zshrc. Keep real secrets ONLY here.

# Vault (example)
# export VAULT_ADDR="https://your-vault-host/"
# export VAULT_TOKEN="<your-vault-token>"

